//problem--2
//swapping of 2 cariables's value using pointers and using functions

#include <iostream>
using namespace std;

void swapNumber(int *ptr1 ,int *ptr2){
    int temp = *ptr1;
    *ptr1 = *ptr2;
    *ptr2 = temp;
}

int main() {
    int a, b;
    cin >> a , b;
    cin >> b;
    swapNumber(&a, &b);
    cout << a <<" "<< b;
}


