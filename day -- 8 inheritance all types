// 1.2 -- encapsulation
#include <iostream>
using namespace std;

class bankaccount{
    private:
    int bankbalance;
public:
    void setbalance(int amount){
        if(amount >= 0){
            bankbalance = amount; 
        }else{
            cout<<"enter a valid amount";
        }
    }
    int getbalance(){
        return bankbalance;
    }
};

int main(){
    bankaccount obj1;
    obj1.setbalance(5000);
    cout<<obj1.getbalance();
}

