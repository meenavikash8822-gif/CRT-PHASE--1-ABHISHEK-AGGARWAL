// PROBLEM --1
//call by value ...and... call by refrence....

#include <iostream>
using namespace std;

void updateByValue(int a)
{
    a = 500;
}
void updateByrefrence(int &a)
{
    a = 500;
}

int main()
{
    int originial = 100;
    cout << " updatebyvalue(originial)";
    cout << originial << "\n";
    updateByrefrence(originial);
    cout << originial;
}


